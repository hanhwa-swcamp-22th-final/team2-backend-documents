<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.CommercialInvoiceQueryMapper">

    <resultMap id="commercialInvoiceResultMap" type="com.team2.documents.query.model.CommercialInvoiceView">
        <id property="commercialInvoiceId" column="ci_id"/>
        <result property="ciId" column="ci_code"/>
        <result property="poId" column="po_id"/>
        <result property="invoiceDate" column="ci_invoice_date"/>
        <result property="clientId" column="client_id"/>
        <result property="currencyId" column="currency_id"/>
        <result property="totalAmount" column="ci_total_amount"/>
        <result property="status" column="ci_status"/>
        <result property="clientName" column="ci_client_name"/>
        <result property="clientAddress" column="ci_client_address"/>
        <result property="country" column="ci_country"/>
        <result property="currencyCode" column="ci_currency_code"/>
        <result property="paymentTerms" column="ci_payment_terms"/>
        <result property="portOfDischarge" column="ci_port_of_discharge"/>
        <result property="buyer" column="ci_buyer"/>
        <result property="itemsSnapshot" column="ci_items_snapshot"/>
        <result property="linkedDocuments" column="ci_linked_documents"/>
        <result property="createdAt" column="created_at"/>
        <!-- PO 에서 query-time JOIN 으로 가져오는 발행 메타. CI INSERT 시점에 스냅샷
             컬럼이 없어 PO 와 같은 스키마(team2_docs) 안에서 JOIN 으로 해소한다. -->
        <result property="incotermsCode" column="po_incoterms_code"/>
        <result property="namedPlace" column="po_named_place"/>
        <result property="deliveryDate" column="po_delivery_date"/>
    </resultMap>

    <sql id="ciColumns">
        ci.ci_id, ci.ci_code, ci.po_id, ci.ci_invoice_date, ci.client_id, ci.currency_id,
        ci.ci_total_amount, ci.ci_status,
        ci.ci_client_name, ci.ci_client_address, ci.ci_country, ci.ci_currency_code,
        ci.ci_payment_terms, ci.ci_port_of_discharge, ci.ci_buyer,
        ci.ci_items_snapshot, ci.ci_linked_documents, ci.created_at,
        po.po_incoterms_code, po.po_named_place, po.po_delivery_date
    </sql>

    <sql id="ciFromJoin">
        FROM commercial_invoices ci
        LEFT JOIN purchase_orders po ON ci.po_id = po.po_id
    </sql>

    <select id="findById" resultMap="commercialInvoiceResultMap">
        SELECT <include refid="ciColumns"/>
        <include refid="ciFromJoin"/>
        WHERE ci.ci_code = #{ciId}
    </select>

    <select id="findAll" resultMap="commercialInvoiceResultMap">
        SELECT <include refid="ciColumns"/>
        <include refid="ciFromJoin"/>
        ORDER BY ci.ci_invoice_date DESC, ci.ci_id DESC
    </select>

    <select id="findPage" resultMap="commercialInvoiceResultMap">
        SELECT <include refid="ciColumns"/>
        <include refid="ciFromJoin"/>
        ORDER BY ci.ci_invoice_date DESC, ci.ci_id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM commercial_invoices
    </select>

</mapper>
