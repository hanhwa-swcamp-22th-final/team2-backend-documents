<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.CommercialInvoiceQueryMapper">

    <resultMap id="commercialInvoiceResultMap" type="com.team2.documents.query.model.CommercialInvoiceView">
        <id property="commercialInvoiceId" column="ci_id"/>
        <result property="ciId" column="ci_code"/>
        <result property="poId" column="po_id"/>
        <result property="invoiceDate" column="ci_invoice_date"/>
        <result property="clientId" column="client_id"/>
        <result property="currencyId" column="currency_id"/>
        <result property="totalAmount" column="ci_total_amount"/>
        <result property="status" column="ci_status"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findById" resultMap="commercialInvoiceResultMap">
        SELECT ci_id, ci_code, po_id, ci_invoice_date, client_id, currency_id,
               ci_total_amount, ci_status, created_at
        FROM commercial_invoices
        WHERE ci_code = #{ciId}
    </select>

    <select id="findAll" resultMap="commercialInvoiceResultMap">
        SELECT ci_id, ci_code, po_id, ci_invoice_date, client_id, currency_id,
               ci_total_amount, ci_status, created_at
        FROM commercial_invoices
        ORDER BY ci_invoice_date DESC, ci_id DESC
    </select>

</mapper>
