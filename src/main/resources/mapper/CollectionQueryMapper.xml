<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.CollectionQueryMapper">

    <resultMap id="collectionResultMap" type="com.team2.documents.query.model.CollectionView">
        <id property="collectionId" column="collection_id"/>
        <result property="poId" column="po_code"/>
        <result property="poNo" column="po_code"/>
        <result property="clientId" column="client_id"/>
        <result property="clientName" column="po_client_name"/>
        <result property="country" column="po_country"/>
        <result property="managerName" column="po_manager_name"/>
        <result property="currencyId" column="currency_id"/>
        <result property="currencyCode" column="po_currency_code"/>
        <result property="totalAmount" column="collection_sales_amount"/>
        <result property="status" column="collection_status"/>
        <!-- collection_issue_date 는 과거 레코드에서 NULL 인 경우가 있어 po 의 po_issue_date 로 fallback.
             둘 다 없으면 비어서 프론트가 안전하게 처리. -->
        <result property="issueDate" column="collection_issue_date_resolved"/>
        <result property="collectionDate" column="collection_completed_date"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="collectionBaseColumns">
        c.collection_id, c.po_id, po.po_code, c.client_id, c.currency_id,
        po.po_currency_code, po.po_client_name, po.po_country, po.po_manager_name,
        c.collection_sales_amount, c.collection_status,
        COALESCE(c.collection_issue_date, po.po_issue_date) AS collection_issue_date_resolved,
        c.collection_completed_date, c.created_at, c.updated_at
    </sql>

    <select id="findById" resultMap="collectionResultMap">
        SELECT <include refid="collectionBaseColumns"/>
        FROM collections c
        JOIN purchase_orders po ON c.po_id = po.po_id
        WHERE c.collection_id = #{id}
    </select>

    <select id="findAll" resultMap="collectionResultMap">
        SELECT <include refid="collectionBaseColumns"/>
        FROM collections c
        JOIN purchase_orders po ON c.po_id = po.po_id
    </select>

    <select id="findPage" resultMap="collectionResultMap">
        SELECT <include refid="collectionBaseColumns"/>
        FROM collections c
        JOIN purchase_orders po ON c.po_id = po.po_id
        ORDER BY c.collection_id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*)
        FROM collections c
        JOIN purchase_orders po ON c.po_id = po.po_id
    </select>

</mapper>
