<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.CollectionQueryMapper">

    <resultMap id="collectionResultMap" type="com.team2.documents.command.domain.entity.Collection">
        <id property="collectionId" column="collection_id"/>
        <result property="poId" column="po_id"/>
        <result property="clientId" column="client_id"/>
        <result property="totalAmount" column="collection_sales_amount"/>
        <result property="status" column="collection_status"/>
        <result property="collectionDate" column="collection_completed_date"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="collectionResultMap">
        SELECT collection_id, po_id, client_id, collection_sales_amount,
               collection_status, collection_completed_date, created_at, updated_at
        FROM collections
        WHERE collection_id = #{id}
    </select>

    <select id="findAll" resultMap="collectionResultMap">
        SELECT collection_id, po_id, client_id, collection_sales_amount,
               collection_status, collection_completed_date, created_at, updated_at
        FROM collections
    </select>

</mapper>
