<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.ProductionOrderQueryMapper">

    <resultMap id="productionOrderResultMap" type="com.team2.documents.entity.ProductionOrder">
        <id property="productionOrderId" column="production_order_id"/>
        <result property="poId" column="po_id"/>
        <result property="orderDate" column="production_issue_date"/>
        <result property="dueDate" column="production_due_date"/>
        <result property="status" column="production_status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="findById" resultMap="productionOrderResultMap">
        SELECT production_order_id, po_id, production_issue_date,
               production_due_date, production_status, created_at, updated_at
        FROM production_orders
        WHERE production_order_id = #{productionOrderId}
    </select>

    <select id="findAll" resultMap="productionOrderResultMap">
        SELECT production_order_id, po_id, production_issue_date,
               production_due_date, production_status, created_at, updated_at
        FROM production_orders
    </select>

</mapper>
