<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.PackingListQueryMapper">

    <resultMap id="packingListResultMap" type="com.team2.documents.query.model.PackingListView">
        <id property="packingListId" column="pl_id"/>
        <result property="plId" column="pl_code"/>
        <result property="poId" column="po_id"/>
        <result property="invoiceDate" column="pl_invoice_date"/>
        <result property="clientId" column="client_id"/>
        <result property="grossWeight" column="pl_gross_weight"/>
        <result property="status" column="pl_status"/>
        <result property="clientName" column="pl_client_name"/>
        <result property="clientAddress" column="pl_client_address"/>
        <result property="country" column="pl_country"/>
        <result property="paymentTerms" column="pl_payment_terms"/>
        <result property="portOfDischarge" column="pl_port_of_discharge"/>
        <result property="buyer" column="pl_buyer"/>
        <result property="itemsSnapshot" column="pl_items_snapshot"/>
        <result property="linkedDocuments" column="pl_linked_documents"/>
        <result property="createdAt" column="created_at"/>
        <!-- purchase_orders JOIN 으로 가져오는 발행 메타. 같은 스키마(team2_docs) 이므로 JOIN OK. -->
        <result property="incotermsCode" column="po_incoterms_code"/>
        <result property="namedPlace" column="po_named_place"/>
        <result property="deliveryDate" column="po_delivery_date"/>
    </resultMap>

    <sql id="plColumns">
        pl.pl_id, pl.pl_code, pl.po_id, pl.pl_invoice_date, pl.client_id, pl.pl_gross_weight, pl.pl_status,
        pl.pl_client_name, pl.pl_client_address, pl.pl_country,
        pl.pl_payment_terms, pl.pl_port_of_discharge, pl.pl_buyer,
        pl.pl_items_snapshot, pl.pl_linked_documents, pl.created_at,
        po.po_incoterms_code, po.po_named_place, po.po_delivery_date
    </sql>

    <sql id="plFromJoin">
        FROM packing_lists pl
        LEFT JOIN purchase_orders po ON pl.po_id = po.po_id
    </sql>

    <select id="findById" resultMap="packingListResultMap">
        SELECT <include refid="plColumns"/>
        <include refid="plFromJoin"/>
        WHERE pl.pl_code = #{plId}
    </select>

    <select id="findAll" resultMap="packingListResultMap">
        SELECT <include refid="plColumns"/>
        <include refid="plFromJoin"/>
        ORDER BY pl.pl_invoice_date DESC, pl.pl_id DESC
    </select>

    <select id="findPage" resultMap="packingListResultMap">
        SELECT <include refid="plColumns"/>
        <include refid="plFromJoin"/>
        ORDER BY pl.pl_invoice_date DESC, pl.pl_id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countAll" resultType="long">
        SELECT COUNT(*) FROM packing_lists
    </select>

</mapper>
