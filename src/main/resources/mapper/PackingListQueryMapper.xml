<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.team2.documents.query.mapper.PackingListQueryMapper">

    <resultMap id="packingListResultMap" type="com.team2.documents.query.model.PackingListView">
        <id property="plId" column="pl_id"/>
        <result property="poId" column="po_id"/>
        <result property="invoiceDate" column="pl_invoice_date"/>
        <result property="clientId" column="client_id"/>
        <result property="grossWeight" column="pl_gross_weight"/>
        <result property="status" column="pl_status"/>
        <result property="clientName" column="pl_client_name"/>
        <result property="clientAddress" column="pl_client_address"/>
        <result property="country" column="pl_country"/>
        <result property="paymentTerms" column="pl_payment_terms"/>
        <result property="portOfDischarge" column="pl_port_of_discharge"/>
        <result property="buyer" column="pl_buyer"/>
        <result property="itemsSnapshot" column="pl_items_snapshot"/>
        <result property="linkedDocuments" column="pl_linked_documents"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <sql id="plColumns">
        pl_id, po_id, pl_invoice_date, client_id, pl_gross_weight, pl_status,
        pl_client_name, pl_client_address, pl_country,
        pl_payment_terms, pl_port_of_discharge, pl_buyer,
        pl_items_snapshot, pl_linked_documents, created_at
    </sql>

    <select id="findById" resultMap="packingListResultMap">
        SELECT <include refid="plColumns"/>
        FROM packing_lists
        WHERE pl_id = #{plId}
    </select>

    <select id="findAll" resultMap="packingListResultMap">
        SELECT <include refid="plColumns"/>
        FROM packing_lists
        ORDER BY pl_invoice_date DESC, pl_id DESC
    </select>

</mapper>
