@@ -0,0 +1,49 @@
+package com.team2.documents.command.service;
+
+import static org.junit.jupiter.api.Assertions.assertTrue;
+
+import java.time.LocalDateTime;
+
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+
+import com.fasterxml.jackson.databind.ObjectMapper;
+
+class DocumentJsonSupportServiceTest {
+
+    private final DocumentJsonSupportService documentJsonSupportService =
+            new DocumentJsonSupportService(new ObjectMapper());
+
+    @Test
+    @DisplayName("linked_documents는 같은 문서 ID와 타입이면 중복 없이 최신 상태로 갱신된다")
+    void appendLinkedDocument_whenSameDocumentIsAddedTwice_thenDeduplicates() {
+        String linkedDocuments = documentJsonSupportService.appendLinkedDocument("[]", "PO2026-0001", "PO", "CONFIRMED", "SOURCE");
+        String updated = documentJsonSupportService.appendLinkedDocument(linkedDocuments, "PO2026-0001", "PO", "REJECTED", "SOURCE");
+
+        assertTrue(updated.contains("\"status\":\"REJECTED\""));
+    }
+
+    @Test
+    @DisplayName("revision_history는 기존 이력 뒤에 새 이벤트를 누적한다")
+    void appendRevision_whenNewEventIsAdded_thenAppends() {
+        String revisionHistory = documentJsonSupportService.createRevisionHistory(
+                "CREATE",
+                2L,
+                "DRAFT",
+                "문서 생성",
+                LocalDateTime.of(2026, 4, 1, 10, 0)
+        );
+        String updated = documentJsonSupportService.appendRevision(
+                revisionHistory,
+                "REQUEST_REGISTRATION",
+                2L,
+                "APPROVAL_PENDING",
+                "등록 요청",
+                LocalDateTime.of(2026, 4, 1, 10, 5)
+        );
+
+        assertTrue(updated.contains("\"action\":\"CREATE\""));
+        assertTrue(updated.contains("\"action\":\"REQUEST_REGISTRATION\""));
+        assertTrue(updated.contains("\"note\":\"등록 요청\""));
+    }
+}
