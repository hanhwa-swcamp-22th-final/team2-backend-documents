diff --git a/src/test/java/com/team2/documents/command/service/ApprovalDocumentMetadataServiceTest.java b/src/test/java/com/team2/documents/command/service/ApprovalDocumentMetadataServiceTest.java
new file mode 100644
index 0000000..ccb21a9
--- /dev/null
+++ b/src/test/java/com/team2/documents/command/service/ApprovalDocumentMetadataServiceTest.java
@@ -0,0 +1,97 @@
+package com.team2.documents.command.service;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.mockito.Mockito.verify;
+import static org.mockito.Mockito.when;
+
+import java.time.LocalDateTime;
+
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.InjectMocks;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import com.team2.documents.entity.ApprovalRequest;
+import com.team2.documents.entity.ProformaInvoice;
+import com.team2.documents.entity.PurchaseOrder;
+import com.team2.documents.entity.enums.ApprovalDocumentType;
+import com.team2.documents.entity.enums.ApprovalRequestType;
+import com.team2.documents.entity.enums.ApprovalStatus;
+import com.team2.documents.entity.enums.ProformaInvoiceStatus;
+import com.team2.documents.entity.enums.PurchaseOrderStatus;
+
+@ExtendWith(MockitoExtension.class)
+class ApprovalDocumentMetadataServiceTest {
+
+    @Mock
+    private PurchaseOrderCommandService purchaseOrderCommandService;
+
+    @Mock
+    private ProformaInvoiceCommandService proformaInvoiceCommandService;
+
+    @Mock
+    private UserSnapshotService userSnapshotService;
+
+    @InjectMocks
+    private ApprovalDocumentMetadataService approvalDocumentMetadataService;
+
+    @Test
+    @DisplayName("PO 결재 요청 생성 시 PO의 결재 메타데이터를 대기 상태로 동기화한다")
+    void markRequested_whenPurchaseOrderApprovalRequest_thenSyncsPendingMetadata() {
+        PurchaseOrder purchaseOrder = new PurchaseOrder("PO2026-0001", PurchaseOrderStatus.APPROVAL_PENDING);
+        ApprovalRequest approvalRequest = new ApprovalRequest(
+                1L,
+                ApprovalDocumentType.PO,
+                "PO2026-0001",
+                ApprovalRequestType.MODIFICATION,
+                2L,
+                1L,
+                "수정 요청",
+                null
+        );
+
+        when(purchaseOrderCommandService.findById("PO2026-0001")).thenReturn(purchaseOrder);
+        when(userSnapshotService.resolveRequesterDisplayName(2L)).thenReturn("Kim");
+
+        approvalDocumentMetadataService.markRequested(approvalRequest);
+
+        assertEquals("대기", purchaseOrder.getApprovalStatus());
+        assertEquals("수정요청", purchaseOrder.getRequestStatus());
+        assertEquals("수정", purchaseOrder.getApprovalAction());
+        assertEquals("Kim", purchaseOrder.getApprovalRequestedBy());
+        verify(purchaseOrderCommandService).save(purchaseOrder);
+    }
+
+    @Test
+    @DisplayName("PI 결재 요청 처리 시 PI의 결재 메타데이터를 승인 결과로 동기화한다")
+    void markReviewed_whenProformaInvoiceApprovalRequest_thenSyncsReviewedMetadata() {
+        ProformaInvoice proformaInvoice = new ProformaInvoice("PI2026-0001", ProformaInvoiceStatus.CONFIRMED);
+        ApprovalRequest approvalRequest = new ApprovalRequest(
+                1L,
+                ApprovalDocumentType.PI,
+                "PI2026-0001",
+                ApprovalRequestType.REGISTRATION,
+                2L,
+                1L,
+                "등록 요청",
+                null
+        );
+        approvalRequest.setStatus(ApprovalStatus.APPROVED);
+        approvalRequest.setReviewSnapshot("승인 완료");
+        approvalRequest.setReviewedAt(LocalDateTime.now());
+
+        when(proformaInvoiceCommandService.findById("PI2026-0001")).thenReturn(proformaInvoice);
+        when(userSnapshotService.resolveRequesterDisplayName(2L)).thenReturn("Lee");
+
+        approvalDocumentMetadataService.markReviewed(approvalRequest);
+
+        assertEquals("승인", proformaInvoice.getApprovalStatus());
+        assertEquals("등록요청", proformaInvoice.getRequestStatus());
+        assertEquals("등록", proformaInvoice.getApprovalAction());
+        assertEquals("Lee", proformaInvoice.getApprovalRequestedBy());
+        assertEquals("승인 완료", proformaInvoice.getApprovalReview());
+        verify(proformaInvoiceCommandService).save(proformaInvoice);
+    }
+}
