+package com.team2.documents.command.service;
+
+import java.time.LocalDateTime;
+import java.util.ArrayList;
+import java.util.LinkedHashMap;
+import java.util.List;
+import java.util.Map;
+import java.util.Objects;
+
+import org.springframework.stereotype.Service;
+
+import com.fasterxml.jackson.core.JsonProcessingException;
+import com.fasterxml.jackson.core.type.TypeReference;
+import com.fasterxml.jackson.databind.ObjectMapper;
+
+@Service
+public class DocumentJsonSupportService {
+
+    private static final TypeReference<List<Map<String, Object>>> LIST_OF_MAPS = new TypeReference<>() {
+    };
+
+    private final ObjectMapper objectMapper;
+
+    public DocumentJsonSupportService(ObjectMapper objectMapper) {
+        this.objectMapper = objectMapper;
+    }
+
+    public String emptyArray() {
+        return writeJson(List.of());
+    }
+
+    public String createRevisionHistory(String action, Long actorUserId, String status, String note, LocalDateTime at) {
+        return writeJson(List.of(createRevisionEntry(action, actorUserId, status, note, at, null)));
+    }
+
+    public String createRevisionHistory(String action,
+                                        Long actorUserId,
+                                        String status,
+                                        String note,
+                                        LocalDateTime at,
+                                        Map<String, Object> changes) {
+        return writeJson(List.of(createRevisionEntry(action, actorUserId, status, note, at, changes)));
+    }
+
+    public String appendLinkedDocument(String currentJson,
+                                       String documentId,
+                                       String documentType,
+                                       String status,
+                                       String relation) {
+        List<Map<String, Object>> documents = new ArrayList<>(readArray(currentJson));
+        documents.removeIf(document -> documentId.equals(document.get("id"))
+                && documentType.equals(document.get("type")));
+        documents.add(createLinkedDocumentEntry(documentId, documentType, status, relation));
+        return writeJson(documents);
+    }
+
+    public String appendRevision(String currentJson,
+                                 String action,
+                                 Long actorUserId,
+                                 String status,
+                                 String note,
+                                 LocalDateTime at) {
+        return appendRevision(currentJson, action, actorUserId, status, note, at, null);
+    }
+
+    public String appendRevision(String currentJson,
+                                 String action,
+                                 Long actorUserId,
+                                 String status,
+                                 String note,
+                                 LocalDateTime at,
+                                 Map<String, Object> changes) {
+        List<Map<String, Object>> revisions = new ArrayList<>(readArray(currentJson));
+        revisions.add(createRevisionEntry(action, actorUserId, status, note, at, changes));
+        return writeJson(revisions);
+    }
+
+    private Map<String, Object> createLinkedDocumentEntry(String documentId,
+                                                          String documentType,
+                                                          String status,
+                                                          String relation) {
+        Map<String, Object> entry = new LinkedHashMap<>();
+        entry.put("id", documentId);
+        entry.put("type", documentType);
+        entry.put("status", status == null ? "" : status);
+        entry.put("relation", relation == null ? "" : relation);
+        return entry;
+    }
+
+    private Map<String, Object> createRevisionEntry(String action,
+                                                    Long actorUserId,
+                                                    String status,
+                                                    String note,
+                                                    LocalDateTime at,
+                                                    Map<String, Object> changes) {
+        Map<String, Object> entry = new LinkedHashMap<>();
+        entry.put("action", action);
+        entry.put("actorUserId", actorUserId == null ? 0L : actorUserId);
+        entry.put("status", status == null ? "" : status);
+        if (note != null && !note.isBlank()) {
+            entry.put("note", note);
+        }
+        if (changes != null && !changes.isEmpty()) {
+            entry.put("changes", changes);
+        }
+        entry.put("at", (at == null ? LocalDateTime.now() : at).toString());
+        return entry;
+    }
+
+    public Map<String, Object> diffSnapshots(Map<String, Object> beforeSnapshot, Map<String, Object> afterSnapshot) {
+        Map<String, Object> changes = new LinkedHashMap<>();
+        if (beforeSnapshot == null || afterSnapshot == null) {
+            return changes;
+        }
+
+        for (Map.Entry<String, Object> entry : afterSnapshot.entrySet()) {
+            Object beforeValue = beforeSnapshot.get(entry.getKey());
+            Object afterValue = entry.getValue();
+            if (!Objects.equals(beforeValue, afterValue)) {
+                Map<String, Object> valueChange = new LinkedHashMap<>();
+                valueChange.put("before", beforeValue);
+                valueChange.put("after", afterValue);
+                changes.put(entry.getKey(), valueChange);
+            }
+        }
+        return changes;
+    }
+
+    private List<Map<String, Object>> readArray(String json) {
+        if (json == null || json.isBlank()) {
+            return List.of();
+        }
+        try {
+            return objectMapper.readValue(json, LIST_OF_MAPS);
+        } catch (JsonProcessingException exception) {
+            throw new IllegalStateException("문서 JSON 파싱에 실패했습니다.", exception);
+        }
+    }
+
+    private String writeJson(Object value) {
+        try {
+            return objectMapper.writeValueAsString(value);
+        } catch (JsonProcessingException exception) {
+            throw new IllegalStateException("문서 JSON 직렬화에 실패했습니다.", exception);
+        }
+    }
+}
