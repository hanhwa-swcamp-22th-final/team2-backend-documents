+import com.team2.documents.entity.PurchaseOrder;
+import com.team2.documents.entity.ShipmentOrder;
+
+@Service
+@Transactional
+public class DocumentLinkService {
+
+    private final DocumentJsonSupportService documentJsonSupportService;
+    private final PurchaseOrderCommandService purchaseOrderCommandService;
+    private final ProformaInvoiceCommandService proformaInvoiceCommandService;
+    private final ProductionOrderCommandService productionOrderCommandService;
+    private final CommercialInvoiceJpaRepository commercialInvoiceJpaRepository;
+    private final PackingListJpaRepository packingListJpaRepository;
+    private final ShipmentOrderJpaRepository shipmentOrderJpaRepository;
+
+    public DocumentLinkService(DocumentJsonSupportService documentJsonSupportService,
+                               PurchaseOrderCommandService purchaseOrderCommandService,
+                               ProformaInvoiceCommandService proformaInvoiceCommandService,
+                               ProductionOrderCommandService productionOrderCommandService,
+                               CommercialInvoiceJpaRepository commercialInvoiceJpaRepository,
+                               PackingListJpaRepository packingListJpaRepository,
+                               ShipmentOrderJpaRepository shipmentOrderJpaRepository) {
+        this.documentJsonSupportService = documentJsonSupportService;
+        this.purchaseOrderCommandService = purchaseOrderCommandService;
+        this.proformaInvoiceCommandService = proformaInvoiceCommandService;
+        this.productionOrderCommandService = productionOrderCommandService;
+        this.commercialInvoiceJpaRepository = commercialInvoiceJpaRepository;
+        this.packingListJpaRepository = packingListJpaRepository;
+        this.shipmentOrderJpaRepository = shipmentOrderJpaRepository;
+    }
+
+    public void linkPurchaseOrderToProformaInvoice(String poId, String piId) {
+        if (piId == null || piId.isBlank()) {
+            return;
+        }
+
+        PurchaseOrder purchaseOrder = purchaseOrderCommandService.findById(poId);
+        ProformaInvoice proformaInvoice = findProformaInvoice(piId).orElse(null);
+        if (proformaInvoice == null) {
+            return;
+        }
+
+        purchaseOrder.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                purchaseOrder.getLinkedDocuments(),
+                piId,
+                "PI",
+                proformaInvoice.getStatus().name(),
+                "SOURCE"
+        ));
+        purchaseOrderCommandService.save(purchaseOrder);
+
+        proformaInvoice.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                proformaInvoice.getLinkedDocuments(),
+                poId,
+                "PO",
+                purchaseOrder.getStatus().name(),
+                "DERIVED"
+        ));
+        proformaInvoiceCommandService.save(proformaInvoice);
+    }
+
+    public void linkAutoGeneratedDocuments(String poId,
+                                           String commercialInvoiceId,
+                                           String packingListId,
+                                           String shipmentOrderId) {
+        PurchaseOrder purchaseOrder = purchaseOrderCommandService.findById(poId);
+
+        purchaseOrder.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                purchaseOrder.getLinkedDocuments(),
+                commercialInvoiceId,
+                "CI",
+                "발행대기",
+                "GENERATED"
+        ));
+        purchaseOrder.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                purchaseOrder.getLinkedDocuments(),
+                packingListId,
+                "PL",
+                "발행대기",
+                "GENERATED"
+        ));
+        purchaseOrder.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                purchaseOrder.getLinkedDocuments(),
+                shipmentOrderId,
+                "SHIPMENT_ORDER",
+                "출하준비",
+                "GENERATED"
+        ));
+        purchaseOrderCommandService.save(purchaseOrder);
+
+        commercialInvoiceJpaRepository.findById(commercialInvoiceId)
+                .ifPresent(commercialInvoice -> saveLinkedDocuments(commercialInvoice, purchaseOrder));
+        packingListJpaRepository.findById(packingListId)
+                .ifPresent(packingList -> saveLinkedDocuments(packingList, purchaseOrder));
+        shipmentOrderJpaRepository.findById(shipmentOrderId)
+                .ifPresent(shipmentOrder -> saveLinkedDocuments(shipmentOrder, purchaseOrder));
+    }
+
+    public void linkProductionOrder(String poId, String productionOrderId, String productionStatus) {
+        PurchaseOrder purchaseOrder = purchaseOrderCommandService.findById(poId);
+        ProductionOrder productionOrder = productionOrderCommandService.findById(productionOrderId);
+
+        purchaseOrder.setLinkedDocuments(documentJsonSupportService.appendLinkedDocument(
+                purchaseOrder.getLinkedDocuments(),
+                productionOrderId,
+                "PRODUCTION_ORDER",
+                productionStatus,
+                "GENERATED"
+        ));
+        purchaseOrderCommandService.save(purchaseOrder);
+
+        productionOrder.setLinkedDocuments(appendUpstreamLinks(
+                productionOrder.getLinkedDocuments(),
+                purchaseOrder,
+                purchaseOrder.getStatus().name(),
+                "SOURCE"
+        ));
+        productionOrderCommandService.save(productionOrder);
+    }
+
+    private Optional<ProformaInvoice> findProformaInvoice(String piId) {
+        try {
+            return Optional.of(proformaInvoiceCommandService.findById(piId));
+        } catch (IllegalArgumentException exception) {
+            return Optional.empty();
+        }
+    }
+
+    private void saveLinkedDocuments(CommercialInvoice commercialInvoice, PurchaseOrder purchaseOrder) {
+        commercialInvoice.setLinkedDocuments(appendUpstreamLinks(
+                commercialInvoice.getLinkedDocuments(),
+                purchaseOrder,
+                purchaseOrder.getStatus().name(),
+                "SOURCE"
+        ));
+        commercialInvoiceJpaRepository.save(commercialInvoice);
+    }
+
+    private void saveLinkedDocuments(PackingList packingList, PurchaseOrder purchaseOrder) {
+        packingList.setLinkedDocuments(appendUpstreamLinks(
+                packingList.getLinkedDocuments(),
+                purchaseOrder,
+                purchaseOrder.getStatus().name(),
+                "SOURCE"
+        ));
+        packingListJpaRepository.save(packingList);
+    }
+
+    private void saveLinkedDocuments(ShipmentOrder shipmentOrder, PurchaseOrder purchaseOrder) {
+        shipmentOrder.setLinkedDocuments(appendUpstreamLinks(
+                shipmentOrder.getLinkedDocuments(),
+                purchaseOrder,
+                purchaseOrder.getStatus().name(),
+                "SOURCE"
+        ));
+        shipmentOrderJpaRepository.save(shipmentOrder);
+    }
+
+    private String appendUpstreamLinks(String currentJson,
+                                       PurchaseOrder purchaseOrder,
+                                       String poStatus,
+                                       String relation) {
+        String linkedDocuments = documentJsonSupportService.appendLinkedDocument(
+                currentJson,
+                purchaseOrder.getPoId(),
+                "PO",
+                poStatus,
+                relation
+        );
+        if (purchaseOrder.getPiId() != null && !purchaseOrder.getPiId().isBlank()) {
+            linkedDocuments = documentJsonSupportService.appendLinkedDocument(
+                    linkedDocuments,
+                    purchaseOrder.getPiId(),
+                    "PI",
+                    "",
+                    "UPSTREAM"
+            );
+        }
+        return linkedDocuments;
+    }
+}
