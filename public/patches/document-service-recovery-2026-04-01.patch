+import org.springframework.data.repository.query.Param;
+
+import com.team2.documents.entity.DocumentNumberSequence;
+
+import jakarta.persistence.LockModeType;
+
+public interface DocumentNumberSequenceRepository extends JpaRepository<DocumentNumberSequence, String> {
+
+    @Lock(LockModeType.PESSIMISTIC_WRITE)
+    @Query("select d from DocumentNumberSequence d where d.sequenceKey = :sequenceKey")
+    Optional<DocumentNumberSequence> findBySequenceKeyForUpdate(@Param("sequenceKey") String sequenceKey);
+}
