+package com.team2.documents.command.service;
+
+import static org.junit.jupiter.api.Assertions.assertEquals;
+import static org.mockito.Mockito.when;
+
+import org.junit.jupiter.api.DisplayName;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+
+import com.team2.documents.client.AuthFeignClient;
+import com.team2.documents.client.AuthUserResponse;
+
+@ExtendWith(MockitoExtension.class)
+class UserSnapshotServiceTest {
+
+    @Mock
+    private AuthFeignClient authFeignClient;
+
+    @Test
+    @DisplayName("auth 응답에 이름이 있으면 결재 요청자 스냅샷으로 이름을 사용한다")
+    void resolveRequesterDisplayName_whenAuthReturnsName_thenUsesName() {
+        AuthUserResponse response = new AuthUserResponse();
+        response.setUserId(2L);
+        response.setName("Kim");
+        when(authFeignClient.getUser(2L)).thenReturn(response);
+
+        UserSnapshotService userSnapshotService = new UserSnapshotService(authFeignClient);
+
+        assertEquals("Kim", userSnapshotService.resolveRequesterDisplayName(2L));
+    }
+
+    @Test
+    @DisplayName("auth 응답에 이름이 없으면 요청자 ID 문자열로 폴백한다")
+    void resolveRequesterDisplayName_whenNameIsMissing_thenFallsBackToUserId() {
+        AuthUserResponse response = new AuthUserResponse();
+        response.setUserId(2L);
+        when(authFeignClient.getUser(2L)).thenReturn(response);
+
+        UserSnapshotService userSnapshotService = new UserSnapshotService(authFeignClient);
+
+        assertEquals("2", userSnapshotService.resolveRequesterDisplayName(2L));
+    }
+
+    @Test
+    @DisplayName("auth 호출이 실패해도 요청자 ID 문자열로 폴백한다")
+    void resolveRequesterDisplayName_whenAuthCallFails_thenFallsBackToUserId() {
+        when(authFeignClient.getUser(2L)).thenThrow(new RuntimeException("auth unavailable"));
+
+        UserSnapshotService userSnapshotService = new UserSnapshotService(authFeignClient);
+
+        assertEquals("2", userSnapshotService.resolveRequesterDisplayName(2L));
+    }
+}
